  "_comment": "Viseme ID → ARKit blendshape weights. Enhanced 22-viseme set. Sources: Apple ARKit 52 blendshapes (developer.apple.com/documentation/arkit/arfaceanchor/blendshapelocation), FACS muscle mapping (melindaozel.com/arkit-to-facs-cheat-sheet), Preston Blair phoneme shapes. Tune weights visually in UE against a mirror.",

  "_arkit_mouth_reference": {
    "jaw":        ["jawOpen", "jawForward", "jawLeft", "jawRight"],
    "lips_close": ["mouthClose", "mouthFunnel", "mouthPucker"],
    "lips_move":  ["mouthLeft", "mouthRight"],
    "smile_frown":["mouthSmileLeft", "mouthSmileRight", "mouthFrownLeft", "mouthFrownRight"],
    "corners":    ["mouthDimpleLeft", "mouthDimpleRight", "mouthStretchLeft", "mouthStretchRight"],
    "press":      ["mouthPressLeft", "mouthPressRight"],
    "roll":       ["mouthRollLower", "mouthRollUpper"],
    "shrug":      ["mouthShrugLower", "mouthShrugUpper"],
    "lip_vert":   ["mouthLowerDownLeft", "mouthLowerDownRight", "mouthUpperUpLeft", "mouthUpperUpRight"],
    "cheek_nose": ["cheekPuff", "noseSneerLeft", "noseSneerRight"],
    "tongue":     ["tongueOut"]
  },

  "_annotations": {
    "V_SIL": "silence / pause",
    "V_BP":  "p, b, m — bilabial stop/nasal. Full lip seal, cheek pressure builds.",
    "V_FV":  "f, v — labiodental. Lower lip raised against upper teeth, upper lip slightly raised.",
    "V_TH":  "θ, ð — dental. Tongue tip slightly between teeth; lips slightly parted and spread.",
    "V_SZ":  "s, z — alveolar sibilant. Narrow jaw, teeth close, slight upper-lip raise.",
    "V_SH":  "ʃ, ʒ, tʃ, dʒ — post-alveolar. Rounded funnel, slight jaw drop.",
    "V_NL":  "n, ŋ, l — alveolar nasal/lateral. Lips slightly parted, neutral, mild nasal activation.",
    "V_R":   "ɹ, r — rhotic. Slight funnel/pucker, jaw partially open, jaw slightly forward.",
    "V_W":   "w — labio-velar approximant. Strong pucker, rounded, jaw nearly closed.",
    "V_H":   "h — glottal fricative. Open jaw, relaxed lips, slight lower-lip drop.",
    "V_TD":  "t, d — alveolar stop. Minimal jaw, slight stretch at lip corners.",
    "V_KG":  "k, g — velar stop. Lips slightly parted, jaw open, no lip action.",
    "V_Y":   "j — palatal approximant. Wide smile-like shape, jaw moderately open.",
    "V_AA":  "ɑ, a, æ — open front/back vowel. Wide jaw, stretched corners.",
    "V_EY":  "eɪ — mid-close front diphthong. Smiling, moderate jaw, upper lip slightly raised.",
    "V_AY":  "aɪ — open→close front diphthong. Starts open, ends spread.",
    "V_AW":  "aʊ — open→round diphthong. Starts open, ends funneled.",
    "V_EH":  "ɛ, e — mid-open front vowel. Smiling, relaxed jaw.",
    "V_IH":  "ɪ, iː, i — close front vowel. Widest smile, minimal jaw.",
    "V_OW":  "oʊ — mid-close back round diphthong. Funnel, moderate jaw.",
    "V_OY":  "ɔɪ — open-mid→close back diphthong.",
    "V_AO":  "ɔ — open-mid back rounded vowel. Open jaw, moderate funnel.",
    "V_UW":  "uː, ʊ, u — close back round vowel. Strong pucker, near-closed jaw.",
    "V_ER":  "ɜː, ɚ — rhotic central vowel. Mid-open jaw, subtle funnel, slight jaw forward.",
    "V_AH":  "ʌ, ə, ɐ — mid-central vowel (schwa/strut). Relaxed, slightly open jaw."
  },

